# ============================================================
# The Kitchen Test™ — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Required — Anthropic API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Kit (ConvertKit) — subscriber email integration
# API key from: https://app.kit.com/account_settings/developer_settings
KIT_API_KEY=your_kit_api_key_here
# The numeric ID of the Kit form to subscribe users to
KIT_FORM_ID=9158283

# Optional — additional webhook URL (Make.com, Zapier, n8n, etc.)
# POST body: { name, email, answers, submittedAt }
# Subscribers are always sent to Kit first; this is a secondary integration.
EMAIL_WEBHOOK_URL=https://your-webhook-url-here.com/endpoint
